# Purrmanent backend environment (plan §21). Copy to .env and fill values.
# NEVER commit a real .env (it is gitignored).

# ── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_GLOBAL_PREFIX=api
FRONTEND_ORIGINS=http://localhost:3000   # comma-separated allow-list

# ── Database ────────────────────────────────────────────────────────────
# Local dev example:
#   postgresql://postgres:password@localhost:5432/purrmanent
# Supabase (prod): postgres://...:5432/postgres?sslmode=require
# Requires the pgvector extension (CREATE EXTENSION vector — handled by migration).
DATABASE_URL=

# ── Auth (better-auth) ──────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
COOKIE_DOMAIN=                            # e.g. .purrmanent.app (prod cross-subdomain)

# ── Email (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY=

# ── AI / RAG (Bynara router, OpenAI-compatible) ─────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://router.bynara.id/v1
LLM_MODEL=mimo-v2.5-free
LLM_MODEL_PRO=mimo-v2.5-pro-free
TAVILY_API_KEY=                           # crisis/coach web-search fallback
# Embeddings run locally (all-MiniLM-L6-v2 via @xenova) — no key needed.

# ── Web Push (VAPID) ────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:team@purrmanent.app

# ── Supabase Storage (cat images) ───────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=cat-images

# ── Misc ────────────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Jakarta                 # default daily-reset / reminder tz
