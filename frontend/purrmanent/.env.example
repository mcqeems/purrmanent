# Frontend environment (copy to .env.local)

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Supabase Storage — direct client image upload (cat photos).
# Use the project URL + a PUBLISHABLE (anon) key, NOT the service role key.
# The bucket (default: cat-images) must allow public read and inserts.
# NOTE: direct client upload means the bucket is effectively world-writable
# with the anon key — acceptable for an MVP, but for production prefer a
# per-user RLS policy (with Supabase Auth) or backend-minted signed upload URLs.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=cat-images
